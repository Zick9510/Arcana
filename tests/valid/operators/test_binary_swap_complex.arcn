func main() -> int {

  int a = 1;
  int b = 2;
  int c = 3;
  int d = a >< b;

  // a = 2
  // b = 1
  // c = 3
  // d = 2

  a = b >< c;

  // a = 3
  // b = 3
  // c = 1
  // d = 2

  c = a >< b;

  // a = 3
  // b = 3
  // c = 3
  // d = 2

  b = d >< a;

  // a = 2
  // b = 3
  // c = 3
  // d = 3

  d = a >< c;

  // a = 3
  // b = 3
  // c = 2
  // d = 3

  return c;

}
