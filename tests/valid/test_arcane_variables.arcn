arcane Twice_TwiceIf (twice: key, twice_if: key, expr1: expr, expr2: expr, block1: code) {

  rules [
    @simple: twice [ block1 ];
    @eval  : twice [ expr1 block1 ];
    @multi : twice [ expr1 expr2 block1 ];
  ];

  @simple {
    twice <=> {
      block1;
      block1;
    };
  }

  @eval {
    twice_if (expr1) <=> {
      if (expr1) {
        block1;
        block1;
      }
    };
  }
  
  @multi {
	twice_if (expr1, expr2) <=> {
		if (expr1) {
			if (expr2) {
				block1;
				block1;
			}
		}
	}
  }
 
 }

func main() -> int {

  int a = 10;
  int b = 11;
  int c = 12;
  int d = 13;

  int x = 1;
  int y = 2;
  int z = 3;
 
  twice {
    x = x + 3;
  }
 
  twice_if (1) {
    y = y + 3;
  }
 
  twice_if (0) {
    z = z + 3;
  }
  
  twice_if (0) (0) {
	a = a + 3;
  }
  
  twice_if (0) (1) {
	b = b + 3;
  }
  
  twice_if (1) (0) {
	c = c + 3;
  }
  
  twice_if (1) (1) {
	d = d + 3;
  }
 
  // x = 7
  // y = 8
  // z = 3
 
  return x + y + z;
}
