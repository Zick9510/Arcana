arcane CustomIf (si: key, sino: key, expr_if: expr, block_if: code, block_else: code) {
  rules [
    @si_rule : si [ expr_if block_if ];

  ];

  @si_rule {
    si (expr_if) <=> {
      if (expr_if) {
        block_if;
      }
    };
  }
}

func main() -> int {

  int x = 1;
  int y = 10;
  int z = 100;

  si (0) {
    x = 10;
  }

  si (1) {
    y = 20;
  }

  si (1 + !1) {
    z = 30;
  }

  return x + y + z;

}
