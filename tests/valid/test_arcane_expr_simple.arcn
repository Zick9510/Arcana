arcane CustomIf (si: key, sino: key, expr_if: expr, block_if: code, block_else: code) {
  rules [
    @si_rule : si   [ expr_if block_if ];
    @no_rule : sino [ block_else       ];

  ];

  @si_rule {
    si (expr_if) <=> {
      if (expr_if) {
        block_if;
      }
	};
  }

  @no_rule {
    sino <=> {
      if (!expr_if) {
		    block_else;
	    }
    };
  }
}

func main() -> int {

  int x = 1;

  si (0) {
    x = 10;
  } sino {
    x = 20;
  }

  return x;

}
