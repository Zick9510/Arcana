arcane CustomLoop (loop: key, block: code) {

  rules [
    @simple: loop [ block ];
  ];

  @simple {

    loop [int a] <=> {
      int i = a;

      while (i) {
        block;
        i = i - 1;
      }

    };

  }
}

func main() -> int {

  int x = 2;

  loop [10] {
    x = x + 3;
  }

  return x;

}
