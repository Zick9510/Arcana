// shape something = [int, float, bool];

func A(int a, int b, float c) -> float;

func B(int a, int b) -> [float, int];

func C(int a, int b, float c) -> float {
  1 + 3;
  //return a * b - c;
  return 3.2;
}

// functions can have returns of different types
func D(int a, int b) -> [int, float] { // May or may not have side effects
  //return a + b + 0.5;
  return -5;
}

pure E(int a, float q) -> void; // Can't have side effects

// An argument can have multiple types
func F([int, float] e) -> [int, float];

