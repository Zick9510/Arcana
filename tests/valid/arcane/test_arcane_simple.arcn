arcane Test (inc: key, block1: code, block2: code) {
  rules [
    @simple: inc [ block1 ];
    @alter : inc [ block1 block2 ];
  ];

  @simple {
    inc <=> {
      block1;
      block1;
      block1;

    };

    inc [int a] <=> {
      block1;
    };

    inc [int a, int b] <=> {
      block1;
      block1;
    };

  }

  @alter {
    inc [int a, int b, int c] <=> {
      if (a) {
		    block1;

      } else {
		    block2;

      }

    };

  }

}

func main() -> int {

	int x = 1;
	int y = 2;
	int z = 3;

  inc {
    z = z + 1; // z = 6
  }

	inc [x] {
		y = y + 18; // y = 20
	}

	inc [x, z] {
		y = y - 3; // y = 14
	}

  inc [x, y, z] {
    x = 5; // x = 5
  } {
    x = 10;
  }

	return x;

}
